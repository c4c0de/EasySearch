@page "/account/change-password"
@attribute [Authorize]
@rendermode InteractiveServer
@using InventoryManagement.Application.Interfaces
@inject ISiteContentRepository ContentRepo

<PageTitle>Change Password</PageTitle>

<div class="form-page">
    <h2 class="page-title">Change Password</h2>
    <p class="muted-hint">Update the dealer login. The password is stored as a salted PBKDF2 hash — never in plain text.</p>

    <div class="card form-card" style="max-width:480px">
        <div class="form-group">
            <label>Current password</label>
            <input type="password" class="filter-input" @bind="currentPassword" @bind:event="oninput" autocomplete="current-password" />
        </div>
        <div class="form-group">
            <label>Username</label>
            <input class="filter-input" @bind="newUsername" autocomplete="username" />
        </div>
        <div class="form-group">
            <label>New password</label>
            <input type="password" class="filter-input" @bind="newPassword" @bind:event="oninput" autocomplete="new-password" />
        </div>
        <div class="form-group">
            <label>Confirm new password</label>
            <input type="password" class="filter-input" @bind="confirmPassword" @bind:event="oninput" autocomplete="new-password" />
        </div>

        @if (!string.IsNullOrEmpty(error)) { <p class="upload-error">@error</p> }
        @if (saved) { <p class="save-confirm">✓ Credential updated. Use the new details next time you sign in.</p> }

        <div class="form-actions">
            <button class="btn-primary" @onclick="Save"
                    disabled="@(saving || string.IsNullOrWhiteSpace(currentPassword) || string.IsNullOrWhiteSpace(newPassword))">
                @(saving ? "Saving…" : "Update Credential")
            </button>
        </div>
    </div>
</div>

@code {
    private string currentPassword = "";
    private string newUsername = "";
    private string newPassword = "";
    private string confirmPassword = "";
    private string? error;
    private bool saving;
    private bool saved;

    protected override async Task OnInitializedAsync()
    {
        var settings = await ContentRepo.GetAllSettingsAsync();
        newUsername = settings.GetValueOrDefault(AuthKeys.Username) ?? "admin";
    }

    private async Task Save()
    {
        error = null; saved = false;

        var settings = await ContentRepo.GetAllSettingsAsync();
        var storedHash = settings.GetValueOrDefault(AuthKeys.PasswordHash);

        if (string.IsNullOrWhiteSpace(storedHash) || !PasswordHasher.Verify(currentPassword, storedHash))
        {
            error = "Current password is incorrect.";
            return;
        }
        if (string.IsNullOrWhiteSpace(newUsername))
        {
            error = "Username cannot be empty.";
            return;
        }
        if (newPassword.Length < 8)
        {
            error = "New password must be at least 8 characters.";
            return;
        }
        if (newPassword != confirmPassword)
        {
            error = "New password and confirmation do not match.";
            return;
        }
        if (newPassword == currentPassword)
        {
            error = "New password must be different from the current one.";
            return;
        }

        saving = true;
        await ContentRepo.SaveSettingsAsync(new Dictionary<string, string>
        {
            [AuthKeys.Username] = newUsername.Trim(),
            [AuthKeys.PasswordHash] = PasswordHasher.Hash(newPassword)
        });
        saving = false;
        saved = true;
        currentPassword = newPassword = confirmPassword = "";
    }
}
