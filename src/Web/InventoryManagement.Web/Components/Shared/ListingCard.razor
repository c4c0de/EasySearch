@using InventoryManagement.Application.DTOs
@using InventoryManagement.Application.Interfaces
@using InventoryManagement.Domain.Enums
@inject IInventoryRepository InventoryRepo
@inject ICategoryRepository CategoryRepo
@inject IStorageService Storage

<div class="listing-card @StatusClass">
    <div class="listing-img-wrap">
        @if (!string.IsNullOrEmpty(Listing.ImageUrl))
        {
            <img src="@Listing.ImageUrl" alt="@Listing.CategoryName" class="listing-img" />
        }
        else
        {
            <div class="no-image-card">No Photo</div>
        }
        <span class="status-badge @StatusClass">@Listing.Status</span>
        @if (!isEditing)
        {
            <button class="img-edit-btn" title="Edit part" @onclick="StartEdit">✏️</button>
        }
    </div>

    @if (isEditing)
    {
        <div class="listing-body listing-edit">
            <label class="edit-label">Photo</label>
            <ImageUpload OnUploaded="OnImageUploaded" />

            <label class="edit-label">Part Name</label>
            <input class="filter-input" @bind="edit.Title" placeholder="Optional name" />

            <label class="edit-label">Car Make</label>
            <input class="filter-input" list="makes-@Listing.Id" @bind="edit.VehicleMake" />
            <datalist id="makes-@Listing.Id">
                @foreach (var m in makes)
                {
                    <option value="@m" />
                }
            </datalist>

            <label class="edit-label">Year</label>
            <input type="number" class="filter-input" @bind="edit.VehicleYear" min="1990" max="2030" />

            <label class="edit-label">Part Type</label>
            <input class="filter-input" list="types-@Listing.Id" @bind="edit.PartType" />
            <datalist id="types-@Listing.Id">
                @foreach (var c in partTypes)
                {
                    <option value="@c.Name" />
                }
            </datalist>

            <label class="edit-label">Price (₹)</label>
            <input type="number" class="filter-input" @bind="edit.Price" />

            <label class="edit-label">Description</label>
            <textarea class="filter-input" rows="2" @bind="edit.Description"></textarea>

            <label class="edit-label">WhatsApp contact</label>
            <select class="filter-input" @bind="edit.WhatsAppAccountId">
                <option value="">— Use default —</option>
                @foreach (var a in whatsAppAccounts)
                {
                    <option value="@a.Id">@a.Display@(a.IsDefault ? " ★" : "")</option>
                }
            </select>

            <label class="edit-label">Instagram contact</label>
            <select class="filter-input" @bind="edit.InstagramAccountId">
                <option value="">— Use default —</option>
                @foreach (var a in instagramAccounts)
                {
                    <option value="@a.Id">@a.Display@(a.IsDefault ? " ★" : "")</option>
                }
            </select>

            <div class="form-actions" style="margin-top:8px">
                <button class="btn-sm-primary" @onclick="SaveEdit"
                        disabled="@(savingEdit || string.IsNullOrWhiteSpace(edit.PartType))">
                    @(savingEdit ? "Saving..." : "Save")
                </button>
                <button class="btn-secondary" @onclick="() => isEditing = false">Cancel</button>
            </div>
        </div>
    }
    else
    {
        <div class="listing-body">
            <p class="listing-vehicle">@Listing.VehicleDisplay</p>
            <h4 class="listing-title">@Listing.Heading</h4>
            @if (!string.IsNullOrWhiteSpace(Listing.Title))
            {
                <p class="listing-subtitle">@Listing.CategoryName</p>
            }
            @if (!string.IsNullOrEmpty(Listing.Description))
            {
                <p class="listing-desc">@Listing.Description</p>
            }
            @if (Listing.Price.HasValue)
            {
                <p class="retail-price">₹@Listing.Price.Value.ToString("N0")</p>
            }
            else
            {
                <p class="listing-desc" style="font-style:italic">Price not set</p>
            }
        </div>

        <div class="listing-actions">
            <select class="status-select" value="@Listing.Status" @onchange="HandleStatusChange">
                @foreach (var s in Enum.GetValues<ListingStatus>())
                {
                    <option value="@s" selected="@(Listing.Status == s)">@s</option>
                }
            </select>
            <button class="btn-sm-danger" style="margin-top:6px;width:100%" @onclick="DeletePart">Delete</button>
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public InventoryListingDto Listing { get; set; } = null!;
    [Parameter] public EventCallback OnChanged { get; set; }

    private static Guid DefaultDealerId => AppConstants.DefaultDealerId;

    private bool isEditing;
    private bool savingEdit;
    private CreateListingDto edit = new();
    private List<string> makes = new();
    private List<InventoryManagement.Domain.Entities.Category> partTypes = new();
    private List<SocialAccountDto> whatsAppAccounts = new();
    private List<SocialAccountDto> instagramAccounts = new();

    private string StatusClass => Listing.Status switch
    {
        ListingStatus.Available => "status-active",
        ListingStatus.Sold => "status-sold",
        ListingStatus.Reserved => "status-reserved",
        _ => ""
    };

    private async Task StartEdit()
    {
        edit = new CreateListingDto
        {
            Id = Listing.Id,
            Title = Listing.Title,
            VehicleMake = Listing.VehicleMake,
            VehicleYear = Listing.VehicleYear,
            PartType = Listing.CategoryName,
            Description = Listing.Description,
            Price = Listing.Price,
            Status = Listing.Status,
            WhatsAppAccountId = Listing.WhatsAppAccountId,
            InstagramAccountId = Listing.InstagramAccountId
        };
        makes = await InventoryRepo.GetDistinctMakesAsync(DefaultDealerId);
        partTypes = await CategoryRepo.GetAllFlatAsync();
        whatsAppAccounts = await InventoryRepo.GetSocialAccountsByTypeAsync(DefaultDealerId, SocialAccountType.WhatsApp);
        instagramAccounts = await InventoryRepo.GetSocialAccountsByTypeAsync(DefaultDealerId, SocialAccountType.Instagram);
        isEditing = true;
    }

    private async Task OnImageUploaded(string url)
    {
        var entity = await InventoryRepo.GetListingByIdAsync(Listing.Id);
        if (entity is not null)
        {
            var oldUrl = entity.ImageUrl;
            entity.ImageUrl = url;
            await InventoryRepo.UpdateListingAsync(entity);
            Listing.ImageUrl = url;

            // Remove the replaced file so uploads don't pile up on the host's disk quota.
            if (!string.IsNullOrEmpty(oldUrl) && oldUrl != url)
                await Storage.DeleteAsync(oldUrl);
        }
    }

    private async Task SaveEdit()
    {
        savingEdit = true;
        var entity = await InventoryRepo.GetListingByIdAsync(Listing.Id);
        if (entity is not null)
        {
            // Vehicle is optional — leave a part unlinked if no make is given.
            if (string.IsNullOrWhiteSpace(edit.VehicleMake))
                entity.VehicleId = null;
            else
                entity.VehicleId = (await InventoryRepo.GetOrCreateVehicleAsync(DefaultDealerId, edit.VehicleMake, edit.VehicleYear)).Id;

            var category = await InventoryRepo.GetOrCreateCategoryAsync(edit.PartType);
            entity.CategoryId = category.Id;
            entity.Title = string.IsNullOrWhiteSpace(edit.Title) ? null : edit.Title!.Trim();
            entity.Description = string.IsNullOrWhiteSpace(edit.Description) ? null : edit.Description!.Trim();
            entity.Price = edit.Price;
            entity.WhatsAppAccountId = edit.WhatsAppAccountId;
            entity.InstagramAccountId = edit.InstagramAccountId;
            await InventoryRepo.UpdateListingAsync(entity);
        }
        savingEdit = false;
        isEditing = false;
        await OnChanged.InvokeAsync();
    }

    private async Task HandleStatusChange(ChangeEventArgs e)
    {
        if (Enum.TryParse<ListingStatus>(e.Value?.ToString(), out var newStatus))
        {
            var entity = await InventoryRepo.GetListingByIdAsync(Listing.Id);
            if (entity is not null)
            {
                entity.Status = newStatus;
                await InventoryRepo.UpdateListingAsync(entity);
                Listing.Status = newStatus;
                await OnChanged.InvokeAsync();
            }
        }
    }

    private async Task DeletePart()
    {
        var imageUrl = Listing.ImageUrl;
        await InventoryRepo.DeleteListingAsync(Listing.Id);
        if (!string.IsNullOrEmpty(imageUrl))
            await Storage.DeleteAsync(imageUrl);
        await OnChanged.InvokeAsync();
    }
}
